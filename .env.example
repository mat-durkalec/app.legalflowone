# Copy to .env and fill in real values before running

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=legalflowone
DB_USER=legalflow
DB_PASSWORD=changeme
MYSQL_ROOT_PASSWORD=rootchangeme

# ── Auth (app.legalflowone.com) ───────────────────────────────────────────────
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (optional — app works without it for demo with email login)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Public URL of the app (used by Auth.js for OAuth callbacks)
NEXTAUTH_URL=https://app.legalflowone.com
